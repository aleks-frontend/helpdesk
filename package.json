{
  "name": "helpdesk",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "e2e"
  ],
  "scripts": {
    "dev": "concurrently -n client,server \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run --workspaces build",
    "test:e2e": "npm run test --workspace=e2e",
    "test:e2e:ui": "npm run test:ui --workspace=e2e"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
