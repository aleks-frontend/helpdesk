# Database — Railway provides this automatically when you attach a Postgres plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Server
PORT=3000
NODE_ENV=production

# Better Auth — generate a random 32+ char string for BETTER_AUTH_SECRET
# e.g. openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="https://your-app.railway.app"
TRUSTED_ORIGINS="https://your-app.railway.app"

# Seed admin credentials (used by prisma/seed.ts — run once after first deploy)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Optional: Sentry error tracking
SENTRY_DSN=""

# Optional: inbound webhook authentication
WEBHOOK_SECRET=""

# Optional: OpenAI (required for AI ticket classification and auto-resolve)
OPENAI_API_KEY=""

# SendGrid outbound email (required for sending replies to customers)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""

# Optional: display name shown in From header (e.g. "Helpdesk Support")
SENDGRID_FROM_NAME=""
