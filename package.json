{
  "name": "helpdesk",
  "private": true,
  "workspaces": [
    "core",
    "client",
    "server",
    "e2e"
  ],
  "scripts": {
    "dev": "concurrently -n client,server \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run --workspaces build",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config=e2e/playwright.config.ts --ui"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
